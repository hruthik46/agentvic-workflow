# v7.91-P3 + P3.2 (F5): consume KAIROS_RAG_{ERROR,EVENT} sentinels from Hermes PTY stderr.
# Publishes to Redis pubsub via a DEDICATED publisher thread + bounded queue —
# the PTY reader MUST NOT block on Redis I/O. During Redis flap, sync publish
# blocks the reader thread for socket_timeout (0.5s) each sentinel, backpressuring
# the Hermes PTY and risking a no-output watchdog false-kill.
RAG_EVENTS_CHANNEL = os.environ.get("KAIROS_RAG_EVENTS_CHANNEL", "kairos:rag:events")

import queue as _rag_queue

# Bounded queue; publisher thread drains. Overflow → put_nowait raises Full → drop silently.
# 1024 buffer is ample for 9-agent fanout emitting ~5 sentinels per session.
_RAG_Q: _rag_queue.Queue = _rag_queue.Queue(maxsize=1024)
_RAG_PUBLISHER_THREAD_STARTED = [False]
_RAG_PUBLISHER_LOCK_START = threading.Lock()


def _rag_publisher_loop():
    """Dedicated background thread — drains _RAG_Q and publishes to Redis.

    Single Redis client, reconnects on failure. Drops payload silently on any
    exception — observability loss is acceptable; PTY-reader-kill is not.
    """
    publisher = None
    while True:
        try:
            payload = _RAG_Q.get()  # block
        except Exception:
            break
        if payload is None:  # poison-pill shutdown signal (unused today)
            break
        try:
            if publisher is None:
                import redis as _redis
                publisher = _redis.Redis(
                    host=REDIS_HOST, port=REDIS_PORT, decode_responses=True,
                    socket_connect_timeout=1.0, socket_timeout=1.0,
                    health_check_interval=30,
                )
            publisher.publish(RAG_EVENTS_CHANNEL, json.dumps(payload))
        except Exception:
            publisher = None  # force reconnect on next try


def _ensure_publisher_thread():
    """Lazy-start the publisher thread on first sentinel."""
    if _RAG_PUBLISHER_THREAD_STARTED[0]:
        return
    with _RAG_PUBLISHER_LOCK_START:
        if _RAG_PUBLISHER_THREAD_STARTED[0]:
            return
        t = threading.Thread(target=_rag_publisher_loop, name="rag-publisher", daemon=True)
        t.start()
        _RAG_PUBLISHER_THREAD_STARTED[0] = True


def _publish_rag_sentinel(line: str, trace_id, agent_name: str) -> None:
    """Parse a KAIROS_RAG_{ERROR,EVENT} sentinel line, enqueue for Redis publish.

    Runs on the PTY reader thread — MUST be non-blocking. Uses bounded queue with
    put_nowait; drops silently on queue full (Redis flap).
    """
    try:
        m = re.match(r"^KAIROS_RAG_(ERROR|EVENT)\s+(\{.*\})\s*$", line)
        if not m:
            return
        try:
            payload = json.loads(m.group(2))
        except (json.JSONDecodeError, ValueError):
            return
        payload["_kind"] = m.group(1)
        payload["_agent"] = agent_name
        if trace_id:
            payload["_trace_id"] = str(trace_id)[:80]
        _ensure_publisher_thread()
        try:
            _RAG_Q.put_nowait(payload)
        except _rag_queue.Full:
            # Drop silently — observability loss is acceptable; PTY-reader-kill is not.
            pass
    except Exception:
        pass

