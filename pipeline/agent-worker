# ── HITL Interrupt Check (v4.0) ─────────────────────────────────────────────────
def check_for_interrupt(gap_id: str = None) -> bool:
    """
    Check if there's a pending HITL interrupt for this agent and gap.
    Returns True if interrupted (agent should pause and wait).
    The orchestrator sets an interrupt:pending:{gap_id}:{agent} key in Redis.
    """
    if not gap_id:
        return False
    if not hitl:
        return False
    try:
        r = get_redis()
        if not r:
            return False
        pending_key = f"interrupt:pending:{gap_id}:{AGENT}"
        if r.exists(pending_key):
            print(f"[{AGENT}] HITL interrupt detected for gap={gap_id}")
            return True
    except Exception as e:
        print(f"[{AGENT}] check_for_interrupt error: {e}")
    return False

def wait_for_interrupt_clear(gap_id: str = None, timeout: int = 300) -> str:
    """
    Wait for a HITL interrupt to be cleared (human responds).
    Returns the interrupt status: 'approved', 'rejected', or 'auto_approved'.
    """
    if not gap_id or not hitl:
        return 'approved'  # No HITL, proceed
    
    interrupt_id_key = f"interrupt:pending:{gap_id}:{AGENT}"
    try:
        r = get_redis()
        if not r:
            return 'approved'
        
        interrupt_id = r.get(interrupt_id_key)
        if not interrupt_id:
            return 'approved'  # No pending interrupt
        
        # Check the interrupt status
        intr_key = f"interrupt:{interrupt_id}"
        intr_data = r.hgetall(intr_key)
        if intr_data:
            status = intr_data.get('status', 'pending')
            if status != 'pending':
                print(f"[{AGENT}] HITL interrupt {interrupt_id} status: {status}")
                return status
        
        # Wait for status change with polling
        start_time = time.time()
        while time.time() - start_time < timeout:
            time.sleep(2)
            intr_data = r.hgetall(intr_key)
            if intr_data:
                status = intr_data.get('status', 'pending')
                if status != 'pending':
                    print(f"[{AGENT}] HITL interrupt {interrupt_id} resolved: {status}")
                    return status
        
        # Timeout — auto-approve
        print(f"[{AGENT}] HITL interrupt timeout for {interrupt_id}, auto-approving")
        return 'auto_approved'
    except Exception as e:
        print(f"[{AGENT}] wait_for_interrupt_clear error: {e}")
        return 'approved'

