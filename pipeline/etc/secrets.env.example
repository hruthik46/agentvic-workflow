# /etc/karios/secrets.env — KAIROS pipeline secrets template
# Copy to /etc/karios/secrets.env on the target node, fill in real values, chmod 600.
# Loaded by every karios-* systemd unit via EnvironmentFile=-/etc/karios/secrets.env

# Redis (host where stream:orchestrator lives — typically the HAProxy VIP for HA)
REDIS_HOST=192.168.118.202
REDIS_PORT=6379
REDIS_USER=karios_admin
REDIS_PASSWORD=<set-on-target>

# Telegram bot for pipeline notifications (notify_phase_transition + telegram_alert)
# Bot must be added to the channel as admin with "Post Messages" permission.
# Channel ID for "Hermes" (KAIROS production) is -1003999467717.
TELEGRAM_BOT_TOKEN=<set-on-target>
TELEGRAM_CHAT_ID=<set-on-target — current channel: -1003981473251 Hemes_106>

# Hermes provider keys per profile — usually live in /root/.hermes/profiles/<agent>/config.yaml
# but you can override via env if needed
HERMES_PROVIDER_API_KEY=<set-on-target>

# Gitea (for autonomous push from agents per v7.4 protocol)
GITEA_BASE_URL=https://gitea.karios.ai
GITEA_API_KEY=<set-on-target>

# A2A JSON-RPC server (port 8090)
KARIOS_A2A_PORT=8090

# Centralized HITL listener — set to 1 on every per-agent service to prevent 9 agents
# long-polling Telegram (HTTP 409 Conflict). Only karios-hitl-listener.service should poll.
KARIOS_HITL_DISABLE_LISTENER=1
