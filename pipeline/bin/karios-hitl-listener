#!/usr/bin/env python3
"""
karios-hitl-listener — single Telegram long-poller for the entire Karios cluster.

Owns the only `getUpdates` long-poll for the bot token. Translates Telegram
commands into Redis state updates that all 9 agents consume.

Why this exists: prior to v6, every agent-worker (and the dispatcher) spawned
their own HITLInterruptHandler thread, each long-polling the same bot. Telegram
permits one long-poll per bot, so 10 concurrent pollers caused HTTP 409
Conflicts and dropped updates.

Commands accepted from the configured chat (TELEGRAM_CHAT_ID):
  /approve <interrupt_id>           — approve a specific HITL interrupt
  /reject  <interrupt_id>           — reject a specific HITL interrupt
  /approve                          — approve the most recent pending interrupt
  /reject                           — reject the most recent pending interrupt
  /pending                          — list all pending interrupts
  /status                           — system health summary
  /stop                             — set META_STOP marker (halts meta-loop)
  /resume                           — clear META_STOP marker
"""
import os
import sys
import json
import time
import urllib.request
import urllib.parse
import redis
from pathlib import Path
from datetime import datetime, timezone

# Env config
TELEGRAM_TOKEN = os.environ.get('TELEGRAM_BOT_TOKEN', '')
TELEGRAM_CHAT_ID = os.environ.get('TELEGRAM_CHAT_ID', '')
REDIS_HOST = os.environ.get('REDIS_HOST', '192.168.118.202')
REDIS_PORT = int(os.environ.get('REDIS_PORT', '6379'))
REDIS_USER = os.environ.get('REDIS_USER', 'karios_admin')
REDIS_PASSWORD = os.environ.get('REDIS_PASSWORD', '')
COORD = Path('/var/lib/karios/coordination')
HEARTBEAT_FILE = Path('/var/lib/karios/heartbeat/hitl-listener.beat')


def _redis():
    return redis.Redis(host=REDIS_HOST, port=REDIS_PORT, db=0,
                       username=REDIS_USER if REDIS_USER else None,
                       password=REDIS_PASSWORD if REDIS_PASSWORD else None,
                       decode_responses=True,
                       socket_timeout=10, socket_connect_timeout=5)


def telegram_send(text: str, parse_mode: str = None) -> bool:
    if not TELEGRAM_TOKEN or not TELEGRAM_CHAT_ID:
        print(f"[hitl-listener] cannot send (no token/chat): {text[:80]}")
        return False
    url = f'https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage'
    data = {'chat_id': TELEGRAM_CHAT_ID, 'text': text}
    if parse_mode:
        data['parse_mode'] = parse_mode
    try:
        req = urllib.request.Request(url, data=urllib.parse.urlencode(data).encode())
        with urllib.request.urlopen(req, timeout=10) as resp:
            body = resp.read().decode('utf-8', errors='replace')
            return '"ok":true' in body
    except Exception as e:
        print(f"[hitl-listener] send failed: {type(e).__name__}: {e}")
        return False


def write_heartbeat():
    try:
        HEARTBEAT_FILE.parent.mkdir(parents=True, exist_ok=True)
        HEARTBEAT_FILE.write_text(str(int(time.time())))
    except Exception as e:
        print(f"[hitl-listener] heartbeat write failed: {e}")


def list_pending_interrupts(r):
    """Scan Redis for interrupt:* hashes that are still pending."""
    pending = []
    for key in r.scan_iter(match='interrupt:*', count=100):
        # Skip pending keys (those are pointers, not interrupt records)
        if key.startswith('interrupt:pending:'):
            continue
        try:
            data = r.hgetall(key)
            if data and data.get('status', 'pending') == 'pending':
                pending.append({
                    'id': data.get('interrupt_id', key.split(':', 1)[1]),
                    'gap_id': data.get('gap_id', '?'),
                    'agent': data.get('agent_id', '?'),
                    'reason': data.get('reason', '')[:80],
                    'age_s': int(time.time() - float(data.get('created_at', time.time()))),
                })
        except Exception:
            continue
    return sorted(pending, key=lambda x: -x['age_s'])


def respond_interrupt(r, interrupt_id: str, status: str, source: str = 'telegram'):
    key = f'interrupt:{interrupt_id}'
    if not r.exists(key):
        return False, f"unknown interrupt_id={interrupt_id}"
    r.hset(key, mapping={
        'status': status,
        'responded_at': str(time.time()),
        'response_by': source,
    })
    # Also clear the pending pointer
    data = r.hgetall(key)
    gap_id = data.get('gap_id')
    agent_id = data.get('agent_id')
    if gap_id and agent_id:
        r.delete(f'interrupt:pending:{gap_id}:{agent_id}')
    return True, data


def handle_command(r, text: str) -> str:
    """Handle a /command from Telegram. Returns reply text."""
    text = text.strip()
    parts = text.split(maxsplit=1)
    cmd = parts[0].lower()
    arg = parts[1].strip() if len(parts) > 1 else ''

    if cmd in ('/approve', '/reject'):
        target_status = 'approved' if cmd == '/approve' else 'rejected'
        if arg:
            ok, info = respond_interrupt(r, arg, target_status)
            if ok:
                return f"✅ {target_status}: {arg} (gap={info.get('gap_id')}, agent={info.get('agent_id')})"
            return f"❌ {info}"
        # No arg — pick most recent pending
        pending = list_pending_interrupts(r)
        if not pending:
            return "no pending interrupts"
        target = pending[0]
        ok, info = respond_interrupt(r, target['id'], target_status)
        return (f"✅ {target_status} (most recent): {target['id']} "
                f"(gap={target['gap_id']}, agent={target['agent']}, age={target['age_s']}s)")

    if cmd == '/pending':
        pending = list_pending_interrupts(r)
        if not pending:
            return "no pending interrupts"
        lines = [f"{p['id']}: gap={p['gap_id']} agent={p['agent']} age={p['age_s']}s — {p['reason']}"
                 for p in pending[:10]]
        return "Pending interrupts:\n" + "\n".join(lines)

    if cmd == '/status':
        # Quick health summary
        agents = ['orchestrator', 'architect', 'backend', 'frontend', 'devops',
                  'tester', 'monitor', 'architect-blind-tester', 'code-blind-tester']
        now = int(time.time())
        rows = []
        for a in agents:
            f = Path(f'/var/lib/karios/heartbeat/{a}.beat')
            if f.exists():
                try:
                    age = now - int(f.read_text().strip())
                    icon = '✓' if age < 120 else '✗'
                    rows.append(f"{icon} {a}: {age}s")
                except Exception:
                    rows.append(f"? {a}: corrupt")
            else:
                rows.append(f"? {a}: no beat")
        # Active gaps
        try:
            state = json.loads((COORD / 'state.json').read_text())
            active = list(state.get('active_gaps', {}).keys())
        except Exception:
            active = ['(state read failed)']
        return f"Agents:\n" + "\n".join(rows) + f"\n\nActive gaps: {active}"

    if cmd == '/stop':
        (COORD / 'META_STOP').write_text(datetime.now(timezone.utc).isoformat())
        return "🛑 META_STOP marker set. Orchestrator will halt the meta-loop on next state-transition check."

    if cmd == '/resume':
        f = COORD / 'META_STOP'
        if f.exists():
            f.unlink()
        return "▶️ META_STOP cleared. Meta-loop may resume."

    if cmd == '/help':
        return ("commands:\n/approve [id]\n/reject [id]\n/pending\n/status\n/stop\n/resume\n/help")

    return ""  # not a recognized command — silent


def handle_update(r, update: dict):
    """Process one Telegram update."""
    # Accept commands from message OR channel_post
    msg = update.get('message') or update.get('channel_post') or update.get('edited_message') or update.get('edited_channel_post')
    if not msg:
        return
    chat_id = str(msg.get('chat', {}).get('id', ''))
    if chat_id != str(TELEGRAM_CHAT_ID):
        # message from a chat we don't trust — ignore silently
        return
    text = msg.get('text', '')
    if not text or not text.startswith('/'):
        return
    reply = handle_command(r, text)
    if reply:
        telegram_send(reply)


def main():
    if not TELEGRAM_TOKEN or not TELEGRAM_CHAT_ID:
        print(f"[hitl-listener] FATAL: TELEGRAM_BOT_TOKEN or TELEGRAM_CHAT_ID not set in env", file=sys.stderr)
        sys.exit(2)
    print(f"[hitl-listener] starting; chat={TELEGRAM_CHAT_ID}", flush=True)
    write_heartbeat()
    telegram_send("[KARIOS hitl-listener] online — type /help for commands")
    r = _redis()
    offset = None
    last_hb = 0
    while True:
        try:
            url = f'https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates'
            params = ['timeout=20',
                      'allowed_updates=' + urllib.parse.quote('["message","channel_post","edited_message","edited_channel_post"]')]
            if offset:
                params.append(f'offset={offset}')
            url += '?' + '&'.join(params)
            with urllib.request.urlopen(url, timeout=25) as resp:
                data = json.loads(resp.read())
            if data.get('ok'):
                for update in data.get('result', []):
                    offset = update['update_id'] + 1
                    try:
                        handle_update(r, update)
                    except Exception as e:
                        print(f"[hitl-listener] handler error: {type(e).__name__}: {e}")
            else:
                print(f"[hitl-listener] getUpdates non-ok: {data}")
                time.sleep(2)
        except Exception as e:
            print(f"[hitl-listener] poll error: {type(e).__name__}: {e}")
            time.sleep(5)
        # heartbeat every ~30s
        now = int(time.time())
        if now - last_hb > 30:
            write_heartbeat()
            last_hb = now


if __name__ == '__main__':
    main()
