#!/usr/bin/env python3
"""
agent-worker — Generic Hermes agent worker v3.0

Improvements over v2.x:
  - Redis Streams inbox: reads from Redis Streams (XREADGROUP) in addition to legacy inbox
  - Streaming: streams progress to Redis pub/sub channel (agent.stream)
  - Checkpointing: saves durable checkpoints at each phase boundary
  - Learnings retrieval: fetches relevant past learnings before each task
  - Structured trace IDs: correlates all operations

Usage:
  agent-worker <agent_name>

Environment:
  REDIS_HOST=192.168.118.202
  REDIS_PORT=6379
  HERMES_AGENT=<agent_name>
"""

# FIX v5.3: Add /usr/local/bin to Python path before importing local modules.
# These modules exist at /usr/local/bin/ but that directory is not in the default
# Python 3.11 search path (/usr/local/lib/python3.11/dist-packages is, but the .py
# files live in /usr/local/bin/ directly). Without this, every agent-worker
# startup crashes with ModuleNotFoundError before it can do anything.
