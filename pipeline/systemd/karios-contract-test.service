[Unit]
Description=Karios Contract Test (v3/v4 import drift, stream consistency, state sync, heartbeats, SOPs)
After=karios-orchestrator-sub.service

[Service]
Type=oneshot
User=root
EnvironmentFile=/etc/karios/secrets.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/local/bin/karios-contract-test
StandardOutput=journal
StandardError=journal
